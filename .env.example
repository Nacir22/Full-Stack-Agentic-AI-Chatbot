# ==========================================================================
# Full-Stack Agentic AI Chatbot — Exemple de configuration d'environnement
# --------------------------------------------------------------------------
# Copier ce fichier en `.env` puis renseigner les valeurs.
#   cp .env.example .env
# NE JAMAIS committer le fichier `.env` réel (voir .gitignore).
# ==========================================================================

# --- Application ----------------------------------------------------------
APP_ENV=development            # development | production
APP_NAME=agentic-chatbot
LOG_LEVEL=INFO                 # DEBUG | INFO | WARNING | ERROR
BACKEND_CORS_ORIGINS=http://localhost:3000

# --- Choix du fournisseur LLM ---------------------------------------------
# Détermine quel client est instancié au runtime (voir core/config.py).
LLM_PROVIDER=openai            # openai | mistral | ollama
LLM_MODEL=gpt-4o-mini          # ex: gpt-4o, gpt-4.1, mistral-large-latest, llama3
LLM_TEMPERATURE=0.2

# --- Clés API LLM (renseigner seulement celle du provider choisi) ---------
OPENAI_API_KEY=
MISTRAL_API_KEY=
# Pour un modèle open-source local via Ollama / API compatible OpenAI :
OLLAMA_BASE_URL=http://localhost:11434/v1

# --- Embeddings -----------------------------------------------------------
EMBEDDING_PROVIDER=openai      # openai | huggingface
EMBEDDING_MODEL=text-embedding-3-small

# --- Monitoring LangSmith -------------------------------------------------
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=agentic-chatbot
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# --- Base de données ------------------------------------------------------
# Production : PostgreSQL. Local rapide : sqlite+aiosqlite:///./app.db
DATABASE_URL=postgresql+psycopg://chatbot:chatbot@db:5432/chatbot
POSTGRES_USER=chatbot
POSTGRES_PASSWORD=chatbot
POSTGRES_DB=chatbot

# --- Vector store (ChromaDB) ----------------------------------------------
CHROMA_PATH=./data/chroma
CHROMA_COLLECTION=documents

# --- RAG -------------------------------------------------------------------
RAG_CHUNK_SIZE=1000
RAG_CHUNK_OVERLAP=150
RAG_TOP_K=4

# --- Frontend (Next.js) ----------------------------------------------------
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
